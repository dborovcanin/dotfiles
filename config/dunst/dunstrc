
[global]
    follow = keyboard
    indicate_hidden = yes
    shrink = yes
    transparency = 0
    separator_height = 2
    padding = 1
    horizontal_padding = 8
    frame_width = 3
    width = (0, 750)
    frame_color = "#F0C674"
    close = ctrl+space
    close_all = ctrl+shift+space
    history = mod1+grave
    context = ctrl+shift+period
    origin = top-center
    dmenu = rofi -dmenu -p dunst
    separator_color = "#C5C8C6"

    # Sort messages by urgency
    sort = yes
    gap_size = 10

    idle_threshold = 120
    font = JetBrains Mono 14
    line_height = 0
    markup = full

    # The format of the message.  Possible variables are:
    #   %a  appname
    #   %s  summary
    #   %b  body
    #   %i  iconname (including its path)
    #   %I  iconname (without its path)
    #   %p  progress value if set ([  0%] to [100%]) or nothing
    #   %n  progress value if set without any extra characters
    #   %%  Literal %
    # Markup is allowed
    format = "<b>%s</b>\n%b"

    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = yes
    icon_position = left
    max_icon_size = 40
    sticky_history = yes
    history_length = 100

    always_run_script = true

    title = Dunst
    class = Dunst
    force_xinerama = false

[experimental]
    per_monitor_dpi = false

[shortcuts]

[urgency_low]
    background = "#282828"
    foreground = "#928374"
    timeout = 5

[urgency_normal]
    background = "#8ABEB7"
    foreground = "#373B41"
    timeout = 5

[urgency_critical]
    background = "#cc2421"
    foreground = "#ebdbb2"
    frame_color = "#fabd2f"
    timeout = 0
