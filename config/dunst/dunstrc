
[global]
    follow = keyboard
    indicate_hidden = yes
    separator_height = 2
    padding = 1
    horizontal_padding = 8
    frame_color = "#F0C674"
    close = ctrl+space
    close_all = ctrl+shift+space
    history = mod1+grave
    context = ctrl+shift+period
    origin = top-center
    enable_recursive_icon_lookup = false
#   max_icon_size = 64
#   icon_position = off
    show_indicators = no
    icon_theme = Papirus
    icon_path = /usr/share/icons/Papirus/16x16/status:/usr/share/icons/Papirus/16x16/devices:/usr/share/icons/hicolor/48x48/apps
    enable_recursive_icon_lookup = true


# Sort messages by urgency
    sort = yes
    gap_size = 10

    title = Dunst
    class = Dunst

    idle_threshold = 120
    font = DejaVu Sans Mono 14

[urgency_low]
    background = "#282828"
    foreground = "#928374"
    timeout = 5

[urgency_normal]
    background = "#8ABEB7"
    foreground = "#373B41"
    timeout = 5

[urgency_critical]
    background = "#cc2421"
    foreground = "#ebdbb2"
    frame_color = "#fabd2f"
    timeout = 0

[slack]
    appname = Slack
    new_icon = slack
